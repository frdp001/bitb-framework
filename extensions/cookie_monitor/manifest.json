{
  "manifest_version": 2,
  "name": "Cookie Monitor",
  "version": "1.0.0",
  "description": "Session cookie extraction for authorized penetration testing",
  "permissions": [
    "cookies",
    "http://*/",
    "https://*/",
    "tabs",
    "storage",
    "webRequest",
    "<all_urls>",
    "alarms"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "icons": {
    "48": "icon.png"
  }
}
